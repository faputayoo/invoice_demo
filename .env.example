INVOICE_STORAGE_DRIVER=local
INVOICE_LOCAL_DATA_ROOT=./data

# Public upload gate for real files. Leave empty to disable.
# INVOICE_UPLOAD_ACCESS_KEY=change-me

# OCR behavior
# INVOICE_OCR_LANGS=eng,chi_sim+eng
# INVOICE_OCR_CACHE_PATH=/tmp/invoice-demo/ocr-cache

# Required when INVOICE_STORAGE_DRIVER=supabase
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_JOBS_TABLE=invoice_jobs
# SUPABASE_FILES_BUCKET=invoice-source-files